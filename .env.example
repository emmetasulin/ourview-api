# ourview.io backend — environment variables
# In Vercel: Project → Settings → Environment Variables (do NOT commit real values).
# To go live with chat, you only need the first three.

# --- Required for AI chat ---
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=        # the "service_role" key from Supabase → Settings → API

